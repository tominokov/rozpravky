# ------------------------------------------------------------------------------
# Basic Application Environment Configuration
# ------------------------------------------------------------------------------
APP_URL="http://localhost:8000"
SESSION_LIFETIME=2592000
SESSION_COOKIE_NAME="APP_SID"

# ------------------------------------------------------------------------------
# Relational Database Configuration Engine (MySQL)
# ------------------------------------------------------------------------------
DB_HOST="127.0.0.1"
DB_PORT=3306
DB_NAME="app_database"
DB_USER="app_user"
DB_PASS="secure_password"
DB_CHARSET="utf8mb4"

# ------------------------------------------------------------------------------
# Alternative Embedded Database Engine (SQLite)
# ------------------------------------------------------------------------------
DB_SQLITE_FILE="db/app.db"

# ------------------------------------------------------------------------------
# Google OAuth2 Authentication Gateway Credentials
# ------------------------------------------------------------------------------
GOOGLE_AUTH_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_AUTH_CLIENT_SECRET="GOCSPX-your-client-secret"
GOOGLE_AUTH_REDIRECT_URI="http://localhost:8000/auth/callback"

# ------------------------------------------------------------------------------
# Google Tag Manager Analytics Deployment
# ------------------------------------------------------------------------------
GOOGLE_TAG_ID="G-XXXXXXXXXX"
